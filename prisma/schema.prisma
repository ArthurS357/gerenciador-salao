generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USUÁRIOS E EQUIPE
// ============================================================

model Cliente {
  id             String        @id @default(uuid())
  nome           String
  telefone       String        @unique
  email          String?
  cpf            String?       @unique
  senhaHash      String?
  anonimizado    Boolean       @default(false)
  ativo          Boolean       @default(true)
  dataNascimento DateTime?                        // ← Feature: Aniversariantes do Mês
  createdAt      DateTime      @default(now())

  agendamentos Agendamento[]
  dividas      DividaCliente[]
  pacoteVendas PacoteVenda[]
}

model Funcionario {
  id               String       @id @default(uuid())
  nome             String
  email            String       @unique
  senhaHash        String
  role             String       @default("PROFISSIONAL")
  comissao         Float        @default(40.0)
  // FLAGS DE CONTROLE DE ACESSO (RBAC)
  podeVerComissao         Boolean      @default(true)
  podeAgendar             Boolean      @default(false)
  podeVerHistorico        Boolean      @default(false)
  podeCancelar            Boolean      @default(false)
  podeGerenciarClientes   Boolean      @default(false) // Recepcionista: criar/editar/anonimizar clientes
  podeVerFinanceiroGlobal Boolean      @default(false) // Recepcionista: ver resumo bruto e taxas (sem alterar config)
  cpf              String?      @unique
  telefone         String?
  descricao        String?
  especialidade    String?
  fotoUrl          String?
  ativo            Boolean      @default(true)

  agendamentos     Agendamento[]
  servicos         Servico[]
  expedientes      Expediente[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Expediente {
  id            String      @id @default(uuid())
  funcionarioId String
  diaSemana     Int
  horaInicio    String
  horaFim       String
  ativo         Boolean     @default(false)

  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, diaSemana])
}

// ============================================================
// 2. CATÁLOGO, PORTFÓLIO, ESTOQUE E PACOTES
// ============================================================

model Servico {
  id               String          @id @default(uuid())
  nome             String
  descricao        String?
  preco            Float?
  tempoMinutos     Int?
  imagemUrl        String?
  ativo            Boolean         @default(true)
  destaque         Boolean         @default(false)

  itensAgendamento ItemServico[]
  funcionarios     Funcionario[]
  insumos          InsumoServico[]
  pacotes          PacoteServico[] // ← NOVO: relação inversa com pacotes
}

model InsumoServico {
  id              String   @id @default(uuid())
  servicoId       String
  produtoId       String
  quantidadeUsada Int

  servico         Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  produto         Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, produtoId])
}

model Produto {
  id               String          @id @default(uuid())
  nome             String
  descricao        String?
  precoCusto       Float?
  precoVenda       Float
  
  estoque          Int             @default(0)
  unidadeMedida    String          @default("un")
  tamanhoUnidade   Int             @default(1)
  
  ativo            Boolean         @default(true)
  
  itensAgendamento ItemProduto[]   
  insumos          InsumoServico[] 

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Pacote {
  id           String          @id @default(uuid())
  nome         String
  descricao    String?
  valorBase    Float           // preço sem desconto
  valorFinal   Float           // preço final cobrado
  desconto     Float           @default(0)    // % de desconto (calculado ou manual)
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  servicos     PacoteServico[]
  vendas       PacoteVenda[]
}

model PacoteServico {
  id         String  @id @default(uuid())
  pacoteId   String
  servicoId  String
  quantidade Int     @default(1)

  pacote     Pacote  @relation(fields: [pacoteId], references: [id], onDelete: Cascade)
  servico    Servico @relation(fields: [servicoId], references: [id])

  @@unique([pacoteId, servicoId])
}

model PacoteVenda {
  id           String    @id @default(uuid())
  pacoteId     String
  clienteId    String
  valorCobrado Float     // snapshot do valorFinal no momento da venda
  status       String    @default("PENDENTE") // "PAGO_ANTECIPADAMENTE" | "PENDENTE"
  criadoEm     DateTime  @default(now())
  paidAt       DateTime?

  pacote       Pacote    @relation(fields: [pacoteId], references: [id])
  cliente      Cliente   @relation(fields: [clienteId], references: [id])

  @@index([clienteId, status])
}

// ============================================================
// 3. MOTOR FINANCEIRO E COMANDAS
// ============================================================

model ConfiguracaoSalao {
  id            String   @id @default("config_global")
  taxaCredito   Float    @default(3.0)   // Legado — substituído por TaxaMetodoPagamento
  taxaDebito    Float    @default(1.5)   // Legado — substituído por TaxaMetodoPagamento
  taxaPix       Float    @default(0.0)   // Legado — substituído por TaxaMetodoPagamento
  atualizadoEm  DateTime @updatedAt
}

model TaxaMetodoPagamento {
  id           String             @id @default(uuid())
  metodo       String
  // Valores válidos: "DINHEIRO" | "PIX" | "CARTAO_DEBITO" | "CARTAO_CREDITO" | "CORTESIA" | "VOUCHER" | "PERMUTA"
  bandeira     String             @default("")
  // "" = genérico (qualquer bandeira); "VISA" | "MASTERCARD" | "ELO" | "AMEX" | "HIPERCARD"
  descricao    String?
  taxaBase     Float              @default(0.0)   // % aplicada sobre o valor (ex: 2.20 para débito)
  ativo        Boolean            @default(true)
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  pagamentos   PagamentoComanda[]

  @@unique([metodo, bandeira])   // substitui o @unique anterior — permite uma taxa genérica + taxas por bandeira
}

model Agendamento {
  id               String             @id @default(uuid())
  clienteId        String
  funcionarioId    String
  dataHoraInicio   DateTime
  dataHoraFim      DateTime
  valorBruto       Float
  concluido        Boolean            @default(false)
  canceladoEm      DateTime?

  // ── Snapshot Financeiro Imutável ──
  taxas            Float              @default(0)
  custoInsumos     Float              @default(0)
  custoRevenda     Float              @default(0)
  valorComissao    Float              @default(0)
  comissaoSnap     Float              @default(0)
  comissaoLiberada Boolean            @default(false)  

  // ── Controle de Pagamento Parcial (NOVOS) ──
  valorPago        Float              @default(0)    
  valorPendente    Float              @default(0)    

  // ── Campos Legado ──
  valorDinheiro    Float              @default(0)   
  valorCartao      Float              @default(0)   
  valorPix         Float              @default(0)   
  metodoPagamento  String?                

  cliente          Cliente            @relation(fields: [clienteId], references: [id])
  funcionario      Funcionario        @relation(fields: [funcionarioId], references: [id])

  servicos         ItemServico[]
  produtos         ItemProduto[]
  avaliacao        Avaliacao?
  pagamentos       PagamentoComanda[] 
  divida           DividaCliente?     

  @@index([funcionarioId, dataHoraInicio, dataHoraFim])
  @@index([concluido, dataHoraInicio])
  @@index([clienteId, valorPendente])  
}

model PagamentoComanda {
  id            String               @id @default(uuid())
  agendamentoId String
  metodo        String
  bandeira      String               @default("")   // snapshot da bandeira usada no fechamento
  valor         Float
  parcelas      Int                  @default(1)
  taxaAplicada  Float                @default(0)
  taxaMetodoId  String?
  criadoEm      DateTime             @default(now())

  agendamento   Agendamento          @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  taxaMetodo    TaxaMetodoPagamento? @relation(fields: [taxaMetodoId], references: [id])

  @@index([agendamentoId])
}

model DividaCliente {
  id            String       @id @default(uuid())
  clienteId     String
  agendamentoId String?      @unique  
  valorOriginal Float               
  valorQuitado  Float        @default(0)
  status        String       @default("PENDENTE") // "PENDENTE" | "QUITADA" | "PARCIAL"
  observacao    String?
  criadoEm      DateTime     @default(now())
  quitadoEm     DateTime?

  cliente       Cliente      @relation(fields: [clienteId], references: [id])
  agendamento   Agendamento? @relation(fields: [agendamentoId], references: [id])

  @@index([clienteId, status])  
}

model ItemServico {
  id            String      @id @default(uuid())
  servicoId     String
  agendamentoId String
  precoCobrado  Float?
  
  servico       Servico     @relation(fields: [servicoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model ItemProduto {
  id            String      @id @default(uuid())
  produtoId     String
  agendamentoId String
  quantidade    Int
  precoCobrado  Float

  produto       Produto     @relation(fields: [produtoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// ============================================================
// 4. VITRINE DE PORTFÓLIO HOMEPAGE
// ============================================================

model ItemPortfolio {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String?              
  valor         Float?
  imagensJson   String               
  linkInstagram String?              
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
}

// ============================================================
// 5. SISTEMA DE ALERTAS
// ============================================================

model Notificacao {
  id       String   @id @default(uuid())
  mensagem String
  lida     Boolean  @default(false)
  criadoEm DateTime @default(now())
}

// ============================================================
// 6. AVALIAÇÕES (NPS)
// ============================================================

model Avaliacao {
  id            String      @id @default(uuid())
  agendamentoId String      @unique
  nota          Int
  comentario    String?
  criadoEm      DateTime    @default(now())

  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// ============================================================
// 7. SISTEMA E LOGS
// ============================================================

model RateLimit {
  identificador String    @id
  count         Int       @default(1)
  windowStart   DateTime  @default(now())
  blockedUntil  DateTime?

  @@map("rate_limits") 
}

model AuditLog {
  id         String   @id @default(cuid())
  usuarioId  String   
  acao       String   
  entidade   String   
  entidadeId String   
  detalhes   String?  
  timestamp  DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([usuarioId])
}