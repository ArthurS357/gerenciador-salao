generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooler (PgBouncer/Neon/Supabase) — runtime
  directUrl = env("DIRECT_URL")     // conexão direta — migrações e introspection
}

// ============================================================
// ENUMS NATIVOS DO POSTGRESQL
// ============================================================

enum RoleFuncionario {
  ADMIN
  PROFISSIONAL
  RECEPCIONISTA
}

enum StatusDivida {
  PENDENTE
  QUITADA
  PARCIAL
}

enum StatusPacoteVenda {
  PENDENTE
  PAGO_ANTECIPADAMENTE
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  FINALIZADO
  CANCELADO
}

// ============================================================
// 1. USUÁRIOS E EQUIPE
// ============================================================

model Cliente {
  id             String        @id @default(uuid())
  nome           String
  telefone       String        @unique
  email          String?
  cpf            String?       @unique
  senhaHash      String?
  anonimizado    Boolean       @default(false)
  ativo          Boolean       @default(true)
  dataNascimento DateTime?                        // ← Feature: Aniversariantes do Mês
  createdAt      DateTime      @default(now())

  agendamentos Agendamento[]
  dividas      DividaCliente[]
  pacoteVendas PacoteVenda[]
}

model Funcionario {
  id               String              @id @default(uuid())
  nome             String
  email            String              @unique
  senhaHash        String
  role             RoleFuncionario     @default(PROFISSIONAL)
  comissao         Decimal             @default(40.0) @db.Decimal(5, 2)
  // FLAGS DE CONTROLE DE ACESSO (RBAC)
  podeVerComissao         Boolean      @default(true)
  podeAgendar             Boolean      @default(false)
  podeVerHistorico        Boolean      @default(false)
  podeCancelar            Boolean      @default(false)
  podeGerenciarClientes   Boolean      @default(false) // Recepcionista: criar/editar/anonimizar clientes
  podeVerFinanceiroGlobal Boolean      @default(false) // Recepcionista: ver resumo bruto e taxas (sem alterar config)
  podeGerenciarEstoque    Boolean      @default(false)
  cpf              String?             @unique
  telefone         String?
  descricao        String?
  especialidade    String?
  fotoUrl          String?
  ativo            Boolean             @default(true)

  agendamentos     Agendamento[]
  servicos         Servico[]
  expedientes      Expediente[]

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Expediente {
  id            String      @id @default(uuid())
  funcionarioId String
  diaSemana     Int
  horaInicio    String
  horaFim       String
  ativo         Boolean     @default(false)

  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, diaSemana])
}

// ============================================================
// 2. CATÁLOGO, PORTFÓLIO, ESTOQUE E PACOTES
// ============================================================

model Servico {
  id               String          @id @default(uuid())
  nome             String
  descricao        String?
  preco            Decimal?        @db.Decimal(10, 2)
  tempoMinutos     Int?
  imagemUrl        String?
  ativo            Boolean         @default(true)
  destaque         Boolean         @default(false)

  itensAgendamento ItemServico[]
  funcionarios     Funcionario[]
  insumos          InsumoServico[]
  pacotes          PacoteServico[]
}

model InsumoServico {
  id              String   @id @default(uuid())
  servicoId       String
  produtoId       String
  quantidadeUsada Int

  servico         Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  produto         Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, produtoId])
}

model Produto {
  id               String          @id @default(uuid())
  nome             String
  descricao        String?
  precoCusto       Decimal?        @db.Decimal(10, 2)
  precoVenda       Decimal         @db.Decimal(10, 2)

  estoque          Int             @default(0)
  unidadeMedida    String          @default("un")
  tamanhoUnidade   Int             @default(1)

  ativo            Boolean         @default(true)

  itensAgendamento ItemProduto[]
  insumos          InsumoServico[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Pacote {
  id           String          @id @default(uuid())
  nome         String
  descricao    String?
  valorBase    Decimal         @db.Decimal(10, 2) // preço sem desconto
  valorFinal   Decimal         @db.Decimal(10, 2) // preço final cobrado
  desconto     Decimal         @default(0) @db.Decimal(10, 2) // % de desconto (calculado ou manual)
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  servicos     PacoteServico[]
  vendas       PacoteVenda[]
}

model PacoteServico {
  id         String  @id @default(uuid())
  pacoteId   String
  servicoId  String
  quantidade Int     @default(1)

  pacote     Pacote  @relation(fields: [pacoteId], references: [id], onDelete: Cascade)
  servico    Servico @relation(fields: [servicoId], references: [id])

  @@unique([pacoteId, servicoId])
}

model PacoteVenda {
  id           String            @id @default(uuid())
  pacoteId     String
  clienteId    String
  valorCobrado Decimal           @db.Decimal(10, 2) // snapshot do valorFinal no momento da venda
  status       StatusPacoteVenda @default(PENDENTE)
  criadoEm     DateTime          @default(now())
  paidAt       DateTime?

  pacote       Pacote    @relation(fields: [pacoteId], references: [id])
  cliente      Cliente   @relation(fields: [clienteId], references: [id])

  @@index([clienteId, status])
}

// ============================================================
// 3. MOTOR FINANCEIRO E COMANDAS
// ============================================================

model TaxaMetodoPagamento {
  id           String             @id @default(uuid())
  metodo       String
  // Valores válidos: "DINHEIRO" | "PIX" | "CARTAO_DEBITO" | "CARTAO_CREDITO" | "CORTESIA" | "VOUCHER" | "PERMUTA"
  bandeira     String             @default("")
  // "" = genérico (qualquer bandeira); "VISA" | "MASTERCARD" | "ELO" | "AMEX" | "HIPERCARD"
  descricao    String?
  taxaBase     Decimal            @default(0.0) @db.Decimal(5, 2)
  ativo        Boolean            @default(true)
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  pagamentos   PagamentoComanda[]

  @@unique([metodo, bandeira])
}

model Agendamento {
  id               String             @id @default(uuid())
  clienteId        String
  funcionarioId    String
  dataHoraInicio   DateTime
  dataHoraFim      DateTime

  status           StatusAgendamento  @default(AGENDADO)

  valorBruto       Decimal            @db.Decimal(10, 2)

  // ── Snapshot Financeiro Imutável ──
  taxas            Decimal            @default(0) @db.Decimal(10, 2)
  custoInsumos     Decimal            @default(0) @db.Decimal(10, 2)
  custoRevenda     Decimal            @default(0) @db.Decimal(10, 2)
  valorComissao    Decimal            @default(0) @db.Decimal(10, 2)
  comissaoSnap     Decimal            @default(0) @db.Decimal(5, 2)
  comissaoLiberada Boolean            @default(false)

  // ── Controle de Pagamento Parcial ──
  valorPago        Decimal            @default(0) @db.Decimal(10, 2)
  valorPendente    Decimal            @default(0) @db.Decimal(10, 2)

  // ── Mensageria ──
  lembreteEnviado  Boolean            @default(false) // ← Cron job marca após enviar lembrete 48h antes

  cliente          Cliente            @relation(fields: [clienteId], references: [id])
  funcionario      Funcionario        @relation(fields: [funcionarioId], references: [id])

  servicos         ItemServico[]
  produtos         ItemProduto[]
  avaliacao        Avaliacao?
  pagamentos       PagamentoComanda[]
  divida           DividaCliente?

  @@index([funcionarioId, dataHoraInicio, dataHoraFim])
  @@index([status, dataHoraInicio])
  @@index([clienteId, valorPendente])
}

model PagamentoComanda {
  id            String               @id @default(uuid())
  agendamentoId String
  metodo        String
  bandeira      String               @default("")   // snapshot da bandeira usada no fechamento
  valor         Decimal              @db.Decimal(10, 2)
  parcelas      Int                  @default(1)
  taxaAplicada  Decimal              @default(0) @db.Decimal(5, 2)
  taxaMetodoId  String?
  criadoEm      DateTime             @default(now())

  agendamento   Agendamento          @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  taxaMetodo    TaxaMetodoPagamento? @relation(fields: [taxaMetodoId], references: [id])

  @@index([agendamentoId])
}

model DividaCliente {
  id            String       @id @default(uuid())
  clienteId     String
  agendamentoId String?      @unique
  valorOriginal Decimal      @db.Decimal(10, 2)
  valorQuitado  Decimal      @default(0) @db.Decimal(10, 2)
  status        StatusDivida @default(PENDENTE)
  observacao    String?
  criadoEm      DateTime     @default(now())
  quitadoEm     DateTime?

  cliente       Cliente      @relation(fields: [clienteId], references: [id])
  agendamento   Agendamento? @relation(fields: [agendamentoId], references: [id])

  @@index([clienteId, status])
}

model ItemServico {
  id            String      @id @default(uuid())
  servicoId     String
  agendamentoId String
  precoCobrado  Decimal?    @db.Decimal(10, 2)

  servico       Servico     @relation(fields: [servicoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model ItemProduto {
  id            String      @id @default(uuid())
  produtoId     String
  agendamentoId String
  quantidade    Int
  precoCobrado  Decimal     @db.Decimal(10, 2)

  produto       Produto     @relation(fields: [produtoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// ============================================================
// 4. VITRINE DE PORTFÓLIO HOMEPAGE
// ============================================================

model ItemPortfolio {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String?
  valor         Decimal? @db.Decimal(10, 2)
  imagensJson   Json                 // ← tipo nativo JSON do PostgreSQL (era String no SQLite)
  linkInstagram String?
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
}

// ============================================================
// 5. SISTEMA DE ALERTAS
// ============================================================

model Notificacao {
  id       String   @id @default(uuid())
  mensagem String
  lida     Boolean  @default(false)
  criadoEm DateTime @default(now())
}

// ============================================================
// 6. AVALIAÇÕES (NPS)
// ============================================================

model Avaliacao {
  id            String      @id @default(uuid())
  agendamentoId String      @unique
  nota          Int
  comentario    String?
  criadoEm      DateTime    @default(now())

  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// ============================================================
// 7. SISTEMA E LOGS
// ============================================================

model RateLimit {
  identificador String    @id
  count         Int       @default(1)
  windowStart   DateTime  @default(now())
  blockedUntil  DateTime?

  @@map("rate_limits")
}

model AuditLog {
  id         String   @id @default(cuid())
  usuarioId  String
  acao       String
  entidade   String
  entidadeId String
  detalhes   String?
  timestamp  DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([usuarioId])
}
