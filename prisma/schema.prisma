generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. USUÁRIOS E EQUIPE

model Cliente {
  id           String        @id @default(uuid())
  nome         String
  telefone     String        @unique
  email        String?
  cpf          String?       @unique
  senhaHash    String?
  anonimizado  Boolean       @default(false)
  
  agendamentos Agendamento[]
}

model Funcionario {
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  senhaHash         String
  role              String        @default("PROFISSIONAL")
  comissao          Float         @default(40.0)
  podeVerComissao   Boolean       @default(true)
  podeAgendar       Boolean       @default(false)
  podeVerHistorico  Boolean       @default(false)
  podeCancelar      Boolean       @default(false)
  cpf               String?       @unique
  telefone          String?
  descricao         String?
  especialidade     String?
  fotoUrl           String?
  ativo             Boolean       @default(true)

  agendamentos     Agendamento[]
  servicos         Servico[]
  expedientes      Expediente[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Expediente {
  id             String      @id @default(uuid())
  funcionarioId  String
  diaSemana      Int
  horaInicio     String
  horaFim        String
  ativo          Boolean     @default(false)

  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, diaSemana])
}

// 2. CATÁLOGO, PORTFÓLIO E ESTOQUE

model Servico {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  preco            Float?
  tempoMinutos     Int?
  imagemUrl        String?
  ativo            Boolean  @default(true)
  destaque         Boolean  @default(false)

  itensAgendamento ItemServico[]
  funcionarios     Funcionario[]
  insumos          InsumoServico[]
}

model InsumoServico {
  id               String   @id @default(uuid())
  servicoId        String
  produtoId        String
  quantidadeUsada  Int

  servico          Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  produto          Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, produtoId])
}

model Produto {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  precoCusto       Float?
  precoVenda       Float
  
  estoque          Int      @default(0)
  unidadeMedida    String   @default("un")
  tamanhoUnidade   Int      @default(1)
  
  ativo            Boolean  @default(true)
  
  itensAgendamento ItemProduto[]   
  insumos          InsumoServico[] 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 3. MOTOR FINANCEIRO E COMANDAS

model ConfiguracaoSalao {
  id            String   @id @default("config_global")
  taxaCredito   Float    @default(3.0)  // % taxa maquininha cartão de crédito
  taxaDebito    Float    @default(1.5)  // % taxa maquininha cartão de débito
  taxaPix       Float    @default(0.0)  // % taxa PIX (geralmente zero)
  atualizadoEm  DateTime @updatedAt
}

model Agendamento {
  id             String   @id @default(uuid())
  clienteId      String
  funcionarioId  String
  dataHoraInicio DateTime
  dataHoraFim    DateTime
  valorBruto     Float
  concluido      Boolean  @default(false)
  canceladoEm    DateTime?

  // ── Snapshot Financeiro Imutável (preenchido somente no fechamento da comanda) ──
  // Estes campos são gravados UMA ÚNICA VEZ quando concluido vira true.
  // Nunca devem ser recalculados dinamicamente; refletem a realidade do momento do atendimento.
  taxas           Float    @default(0)   // Total de taxas da maquininha (incide só sobre o valor em cartão)
  custoInsumos    Float    @default(0)   // Insumos consumidos (validado/editado pelo operador)
  custoRevenda    Float    @default(0)   // precoCusto × quantidade de cada produto vendido
  valorComissao   Float    @default(0)   // Repasse ao profissional (sobre baseLiquida)
  comissaoSnap    Float    @default(0)   // % de comissão congelada no momento do fechamento

  // ── Detalhamento do Pagamento (snapshot da divisão por método) ──
  valorDinheiro   Float    @default(0)   // Parte paga em dinheiro físico
  valorCartao     Float    @default(0)   // Parte paga em cartão (crédito ou débito)
  valorPix        Float    @default(0)   // Parte paga em PIX
  metodoPagamento String?               // "DINHEIRO" | "CARTAO_CREDITO" | "CARTAO_DEBITO" | "PIX" | "MISTO"

  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])

  servicos       ItemServico[]
  produtos       ItemProduto[]
  avaliacao      Avaliacao?

  @@index([funcionarioId, dataHoraInicio, dataHoraFim]) // Anti-double-booking
  @@index([concluido, dataHoraInicio])                  // Relatórios financeiros (full scan → index range scan)
}

model ItemServico {
  id            String      @id @default(uuid())
  servicoId     String
  agendamentoId String
  precoCobrado  Float?
  servico       Servico     @relation(fields: [servicoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model ItemProduto {
  id            String      @id @default(uuid())
  produtoId     String
  agendamentoId String
  quantidade    Int
  precoCobrado  Float

  produto       Produto     @relation(fields: [produtoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// 4. Vitrine de portfólio homepage
model ItemPortfolio {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String?              // Descrição detalhada do trabalho
  valor         Float?
  imagensJson   String               // Array JSON: ["img1.png","img2.png"] — suporte a até 4 fotos
  linkInstagram String?              // Link direto para o post/perfil no Instagram
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
}

// 5. SISTEMA DE ALERTAS
model Notificacao {
  id        String   @id @default(uuid())
  mensagem  String
  lida      Boolean  @default(false)
  criadoEm  DateTime @default(now())
}

// 6. AVALIAÇÕES (NPS)
model Avaliacao {
  id            String      @id @default(uuid())
  agendamentoId String      @unique
  nota          Int
  comentario    String?
  criadoEm      DateTime    @default(now())

  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model RateLimit {
  identificador String    @id
  count         Int       @default(1)
  windowStart   DateTime  @default(now())
  blockedUntil  DateTime?

  @@map("rate_limits") // Opcional: padroniza o nome da tabela no banco
}

model AuditLog {
  id            String   @id @default(cuid())
  usuarioId     String   // Quem fez a ação
  acao          String   // EX: "FECHAMENTO_COMANDA", "ALTERACAO_PRECO"
  entidade      String   // EX: "Comanda", "Servico"
  entidadeId    String   // ID do registro afetado
  detalhes      String?  // JSON ou descrição da mudança
  timestamp     DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([usuarioId])
}