generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. USUÁRIOS E EQUIPE

model Cliente {
  id           String        @id @default(uuid())
  nome         String
  telefone     String
  senhaHash    String?
  anonimizado  Boolean       @default(false)
  
  agendamentos Agendamento[]
}

model Funcionario {
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  senhaHash         String
  role              String        @default("PROFISSIONAL")
  comissao          Float         @default(40.0)
  podeVerComissao   Boolean       @default(true) // Admin define se o profissional vê a %
  podeAgendar       Boolean       @default(false)
  podeVerHistorico  Boolean       @default(false)
  cpf               String?       @unique
  telefone          String?
  descricao         String?
  especialidade     String?
  fotoUrl           String?
  ativo             Boolean       @default(true)

  agendamentos     Agendamento[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// 2. CATÁLOGO, PORTFÓLIO E ESTOQUE

model Servico {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  preco            Float?   // Opcional: Se nulo, fica "Sob Consulta" ou invisível
  tempoMinutos     Int?     // Opcional: Admin define se o serviço tem tempo fixo
  imagemUrl        String?  // Referência visual para a Landing Page (Portfólio)
  ativo            Boolean  @default(true)

  itensAgendamento ItemServico[]
}

model Produto {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  precoCusto  Float    @default(0.0)
  precoVenda  Float
  estoque     Int      @default(0)
  ativo       Boolean  @default(true)

  itensAgendamento ItemProduto[]
  estoqueMinimo Int @default(5)
}

// 3. MOTOR FINANCEIRO E COMANDAS

model Agendamento {
  id             String    @id @default(uuid())
  clienteId      String
  funcionarioId  String
  dataHoraInicio DateTime
  dataHoraFim    DateTime
  valorBruto     Float     // Soma total em cache (Serviços + Produtos)
  taxas          Float     @default(0)
  concluido      Boolean   @default(false)

  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])

  // Um agendamento agora pode ter N serviços e N produtos atrelados
  servicos       ItemServico[]
  produtos       ItemProduto[]
}

// Tabela pivô para registrar quais serviços estão nesta comanda
model ItemServico {
  id            String      @id @default(uuid())
  servicoId     String
  agendamentoId String
  precoCobrado  Float?      // Salva o preço no momento do agendamento para blindar o histórico

  servico       Servico     @relation(fields: [servicoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// Tabela pivô para dar baixa no estoque e cobrar produtos na comanda
model ItemProduto {
  id            String      @id @default(uuid())
  produtoId     String
  agendamentoId String
  quantidade    Int
  precoCobrado  Float       // Salva o valor de venda no momento da transação

  produto       Produto     @relation(fields: [produtoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// 4. Vitrine de portfólio homepage
model ItemPortfolio {
  id          String   @id @default(uuid())
  titulo      String   // Ex: "Mechas e Iluminação"
  valor       Float?   // Ex: 450.00
  imagemUrl   String   // URL que virá do Cloudinary/S3
  linkSocial  String?  // URL do post no Instagram/TikTok
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
}