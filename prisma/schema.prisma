generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. USUÁRIOS E EQUIPE

model Cliente {
  id           String        @id @default(uuid())
  nome         String
  telefone     String
  senhaHash    String?
  anonimizado  Boolean       @default(false)
  
  agendamentos Agendamento[]
}

model Funcionario {
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  senhaHash         String
  role              String        @default("PROFISSIONAL")
  comissao          Float         @default(40.0)
  podeVerComissao   Boolean       @default(true)
  podeAgendar       Boolean       @default(false)
  podeVerHistorico  Boolean       @default(false)
  podeCancelar      Boolean       @default(false)
  cpf               String?       @unique
  telefone          String?
  descricao         String?
  especialidade     String?
  fotoUrl           String?
  ativo             Boolean       @default(true)

  agendamentos     Agendamento[]
  servicos         Servico[]      // Serviços que o profissional está apto a executar
  expedientes      Expediente[]


  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Expediente {
  id             String      @id @default(uuid())
  funcionarioId  String
  diaSemana      Int         // 0 = Domingo, 1 = Segunda, 2 = Terça, 3 = Quarta, 4 = Quinta, 5 = Sexta, 6 = Sábado
  horaInicio     String      // Ex: "09:00"
  horaFim        String      // Ex: "18:00"
  ativo          Boolean     @default(false) // Se true, ele trabalha neste dia

  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, diaSemana]) // Garante que só existe 1 registo por dia da semana para cada funcionário
}

// 2. CATÁLOGO, PORTFÓLIO E ESTOQUE

model Servico {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  preco            Float?
  tempoMinutos     Int?
  imagemUrl        String?
  ativo            Boolean  @default(true)

  destaque         Boolean  @default(false)

  itensAgendamento ItemServico[]
  funcionarios     Funcionario[]  // Profissionais aptos a realizar este serviço
  insumos          InsumoServico[]
}

model InsumoServico {
  id               String   @id @default(uuid())
  servicoId        String
  produtoId        String
  quantidadeUsada  Int      // Quantidade gasta por atendimento (ex: 25)

  servico          Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  produto          Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([servicoId, produtoId]) // Evita que o mesmo produto seja cadastrado duas vezes no mesmo serviço
}

model Produto {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  precoCusto       Float?   // Preço pago por 1 frasco inteiro
  precoVenda       Float    // Preço se for vendido inteiro (revenda)
  
  estoque          Int      @default(0)    // Total absoluto (em ml, g ou unidades)
  unidadeMedida    String   @default("un") // "ml", "g", "un"
  tamanhoUnidade   Int      @default(1)    // Capacidade de 1 frasco (ex: 700 para 700ml)
  
  ativo            Boolean  @default(true)
  
  itensAgendamento ItemProduto[]   // <-- CORREÇÃO: alterado de ItemServico para ItemProduto
  insumos          InsumoServico[] // <-- RELAÇÃO COM A FICHA TÉCNICA

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// 3. MOTOR FINANCEIRO E COMANDAS

model Agendamento {
  id             String   @id @default(uuid())
  clienteId      String
  funcionarioId  String
  dataHoraInicio DateTime
  dataHoraFim    DateTime
  valorBruto     Float
  taxas          Float    @default(0)
  concluido      Boolean  @default(false)
  
  custoInsumos   Float    @default(0) 

  cliente        Cliente     @relation(fields: [clienteId], references: [id])
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id])

  servicos       ItemServico[]
  produtos       ItemProduto[]
}

model ItemServico {
  id            String      @id @default(uuid())
  servicoId     String
  agendamentoId String
  precoCobrado  Float?

  servico       Servico     @relation(fields: [servicoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

model ItemProduto {
  id            String      @id @default(uuid())
  produtoId     String
  agendamentoId String
  quantidade    Int
  precoCobrado  Float

  produto       Produto     @relation(fields: [produtoId], references: [id])
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}

// 4. Vitrine de portfólio homepage
model ItemPortfolio {
  id          String   @id @default(uuid())
  titulo      String
  valor       Float?
  imagemUrl   String
  linkSocial  String?
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
}

// 5. SISTEMA DE ALERTAS
model Notificacao {
  id        String   @id @default(uuid())
  mensagem  String
  lida      Boolean  @default(false)
  criadoEm  DateTime @default(now())
}