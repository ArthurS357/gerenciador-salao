generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
model Cliente {
  id             String        @id @default(uuid())
  telefone       String        @unique // Evita duplicidade no login
  nome           String
  anonimizado    Boolean       @default(false) // Flag para a LGPD
  criadoEm       DateTime      @default(now())
  agendamentos   Agendamento[]
}

model Funcionario {
  id               String       @id @default(cuid())
  nome             String
  email            String       @unique
  senhaHash        String
  role             String       @default("PROFISSIONAL")

  // ✅ Campos que estavam faltando
  cpf              String?      @unique
  telefone         String?
  especialidade    String?
  descricao        String?
  comissao         Float        @default(40.0)
  podeAgendar      Boolean      @default(false)
  podeVerHistorico Boolean      @default(false)
  ativo            Boolean      @default(true)

  agendamentos     Agendamento[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum Role {
  ADMIN
  PROFISSIONAL
}

model Agendamento {
  id            String      @id @default(uuid())
  clienteId     String
  cliente       Cliente     @relation(fields: [clienteId], references: [id])
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  valorBruto    Float
  taxas         Float       // Deduções (cartão, insumos) para cálculo real
  dataHoraInicio DateTime   // Alterado para suportar o Buffer Invisível
  dataHoraFim    DateTime   // Alterado para suportar o Buffer Invisível
  concluido     Boolean     @default(false)
}